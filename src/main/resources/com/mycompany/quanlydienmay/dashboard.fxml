<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/13" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.quanlydienmay.main.DashboardController" styleClass="root-container">
    <top>
        <VBox spacing="20.0" styleClass="header-container">
            <padding>
                <Insets top="24" right="32" bottom="24" left="32"/>
            </padding>

            <!-- Header Bar -->
            <HBox alignment="CENTER_LEFT" spacing="16" styleClass="header-bar">
                <Label text="📱 Quản Lý Điện Máy" styleClass="app-title" HBox.hgrow="ALWAYS"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblWelcome" text="" styleClass="welcome-text"/>
                <Button text="🚪 Đăng xuất" onAction="#handleLogout" styleClass="logout-button"/>
            </HBox>
            
            <!-- Subtitle -->
            <Label text="Hệ thống quản lý bán hàng điện máy gia dụng" styleClass="subtitle-text"/>

            <!-- Summary Cards Row -->
            <HBox spacing="16.0" styleClass="stats-container">
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <padding>
                        <Insets top="16" right="16" bottom="16" left="16"/>
                    </padding>
                    <Label text="📦" styleClass="stat-icon"/>
                    <Label text="Danh mục" styleClass="stat-label"/>
                    <Label fx:id="lblTotalCategories" text="0" styleClass="stat-number"/>
                </VBox>
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <padding>
                        <Insets top="16" right="16" bottom="16" left="16"/>
                    </padding>
                    <Label text="🛒" styleClass="stat-icon"/>
                    <Label text="Sản phẩm" styleClass="stat-label"/>
                    <Label fx:id="lblTotalProducts" text="0" styleClass="stat-number"/>
                </VBox>
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <padding>
                        <Insets top="16" right="16" bottom="16" left="16"/>
                    </padding>
                    <Label text="📋" styleClass="stat-icon"/>
                    <Label text="Đơn hàng" styleClass="stat-label"/>
                    <Label fx:id="lblTotalOrders" text="0" styleClass="stat-number"/>
                </VBox>
            </HBox>
        </VBox>
    </top>

    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE" styleClass="main-tabs">
            <tabs>
                <Tab fx:id="tabCategory" text="Danh mục">
                    <VBox spacing="10" styleClass="tab-content">
                        <padding>
                            <Insets top="16" right="16" bottom="16" left="16"/>
                        </padding>
                        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="toolbar-row">
                            <TextField fx:id="txtCategorySearch" promptText="Tìm danh mục..." styleClass="search-field" HBox.hgrow="ALWAYS"/>
                            <Button text="Làm mới" onAction="#handleRefresh" styleClass="ghost-button"/>
                        </HBox>
                        <TableView fx:id="categoryTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="categoryIdCol" text="ID" prefWidth="120"/>
                                <TableColumn fx:id="categoryNameCol" text="Tên danh mục" prefWidth="650"/>
                            </columns>
                        </TableView>
                    </VBox>
                </Tab>

                <Tab fx:id="tabProduct" text="Sản phẩm">
                    <VBox spacing="10" styleClass="tab-content">
                        <padding>
                            <Insets top="16" right="16" bottom="16" left="16"/>
                        </padding>
                        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="toolbar-row">
                            <TextField fx:id="txtProductSearch" promptText="Tìm sản phẩm hoặc danh mục..." styleClass="search-field" HBox.hgrow="ALWAYS"/>
                            <Button text="Làm mới" onAction="#handleRefresh" styleClass="ghost-button"/>
                        </HBox>
                        <TableView fx:id="productTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="productIdCol" text="ID" prefWidth="80"/>
                                <TableColumn fx:id="productNameCol" text="Tên sản phẩm" prefWidth="300"/>
                                <TableColumn fx:id="productCategoryCol" text="Danh mục" prefWidth="200"/>
                                <TableColumn fx:id="productPriceCol" text="Giá" prefWidth="180"/>
                                <TableColumn fx:id="productStockCol" text="Tồn kho" prefWidth="120"/>
                            </columns>
                        </TableView>
                    </VBox>
                </Tab>

                <Tab fx:id="tabOrder" text="Đơn hàng">
                    <VBox spacing="10" styleClass="tab-content">
                        <padding>
                            <Insets top="16" right="16" bottom="16" left="16"/>
                        </padding>
                        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="toolbar-row">
                            <TextField fx:id="txtOrderSearch" promptText="Tìm khách hàng, SĐT hoặc trạng thái..." styleClass="search-field" HBox.hgrow="ALWAYS"/>
                            <Button text="Làm mới" onAction="#handleRefresh" styleClass="ghost-button"/>
                        </HBox>
                        <TableView fx:id="orderTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="orderIdCol" text="Mã đơn" prefWidth="80"/>
                                <TableColumn fx:id="orderCustomerCol" text="Khách hàng" prefWidth="220"/>
                                <TableColumn fx:id="orderPhoneCol" text="SĐT" prefWidth="150"/>
                                <TableColumn fx:id="orderDateCol" text="Ngày đặt" prefWidth="180"/>
                                <TableColumn fx:id="orderStatusCol" text="Trạng thái" prefWidth="160"/>
                                <TableColumn fx:id="orderTotalCol" text="Tổng tiền" prefWidth="180"/>
                            </columns>
                        </TableView>
                    </VBox>
                </Tab>

                <Tab fx:id="tabAccount" text="Tài khoản (Admin)">
                    <VBox spacing="10" styleClass="tab-content">
                        <padding>
                            <Insets top="16" right="16" bottom="16" left="16"/>
                        </padding>
                        <Label text="Chức năng quản lý tài khoản – chỉ dành cho ADMIN" styleClass="field-label"/>
                    </VBox>
                </Tab>
            </tabs>
        </TabPane>
    </center>
</BorderPane>