<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/13" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.mycompany.quanlydienmay.main.LoginController"
           styleClass="login-root">

    <VBox styleClass="login-card" maxWidth="520" maxHeight="680">
        <padding>
            <Insets top="44" right="48" bottom="44" left="48"/>
        </padding>

        <!-- Logo + Title -->
        <HBox alignment="CENTER" spacing="10">
            <Label text="⚡" style="-fx-font-size: 36;"/>
        </HBox>

        <Label text="Quản Lý Điện Máy" styleClass="login-title"
               style="-fx-alignment: CENTER; -fx-text-alignment: CENTER; -fx-padding: 12 0 0 0;"/>
        <Label text="Đăng nhập vào hệ thống của bạn" styleClass="login-subtitle"
               style="-fx-alignment: CENTER; -fx-text-alignment: CENTER;"/>

        <Separator style="-fx-padding: 8 0 8 0; -fx-opacity: 0.3;"/>

        <Label text="Tên đăng nhập" styleClass="field-label"/>
        <TextField fx:id="txtUsername" promptText="Nhập tên đăng nhập" styleClass="login-field"/>

        <Label text="Mật khẩu" styleClass="field-label"/>
        <PasswordField fx:id="txtPassword" promptText="Nhập mật khẩu" styleClass="login-field"/>

        <Label fx:id="lblError" text="" styleClass="error-label" wrapText="true"
               style="-fx-padding: 8 0 4 0;"/>

        <Button fx:id="btnLogin" text="Đăng Nhập →" onAction="#handleLogin"
                styleClass="login-btn" maxWidth="Infinity"
                style="-fx-padding: 18 28 18 28; -fx-margin: 12 0 0 0;"/>

        <Button text="Chưa có tài khoản? Đăng ký ngay" onAction="#handleRegister" styleClass="link-button"
                style="-fx-padding: 16 0 0 0; -fx-alignment: CENTER; -fx-max-width: Infinity;" />

        <HBox alignment="CENTER" style="-fx-padding: 16 0 0 0;">
            <Label text="💡 ADMIN: admin / admin123  |  USER: user / user123"
                   styleClass="hint-label"/>
        </HBox>
    </VBox>
</StackPane>
