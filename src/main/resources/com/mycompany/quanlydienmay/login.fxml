<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/13" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.mycompany.quanlydienmay.main.LoginController"
           styleClass="login-root">

    <VBox styleClass="login-card" maxWidth="420" maxHeight="500">
        <padding>
            <Insets top="48" right="48" bottom="48" left="48"/>
        </padding>

        <Label text="Quản Lý Điện Máy" styleClass="login-title"/>
        <Label text="Đăng nhập để tiếp tục" styleClass="login-subtitle"/>

        <Label text="Tên đăng nhập" styleClass="field-label"/>
        <TextField fx:id="txtUsername" promptText="Nhập tên đăng nhập" styleClass="login-field"/>

        <Label text="Mật khẩu" styleClass="field-label"/>
        <PasswordField fx:id="txtPassword" promptText="Nhập mật khẩu" styleClass="login-field"/>

        <Label fx:id="lblError" text="" styleClass="error-label" wrapText="true"/>

        <Button fx:id="btnLogin" text="Đăng Nhập" onAction="#handleLogin"
                styleClass="login-btn" maxWidth="Infinity"/>

        <HBox alignment="CENTER">
            <Label text="ADMIN: admin / admin123  |  CUSTOMER: user / user123"
                   styleClass="hint-label"/>
        </HBox>
    </VBox>
</StackPane>
